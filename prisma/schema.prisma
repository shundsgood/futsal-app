generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          String   @id
  email       String   @unique
  displayName String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  ownedTeams   Team[]
  teamMembers  TeamMember[]
  createdPolls SchedulePoll[]
  createdEvents Event[]
}

model Team {
  id           String   @id @default(cuid())
  name         String
  description  String?
  activityArea String?
  ownerUserId  String
  inviteCode   String?  @unique
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  owner   User         @relation(fields: [ownerUserId], references: [id])
  members TeamMember[]
  polls   SchedulePoll[]
  events  Event[]
  matches Match[]
}

model TeamMember {
  id               String    @id @default(cuid())
  teamId           String
  userId           String
  displayName      String
  uniformNumber    Int?
  position         String?
  uniformSize      String?
  // active | inactive | left
  membershipStatus String    @default("active")
  // owner | admin | member
  role             String    @default("member")
  joinedAt         DateTime?
  notes            String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  team              Team                   @relation(fields: [teamId], references: [id])
  user              User                   @relation(fields: [userId], references: [id])
  responses         SchedulePollResponse[]
  eventAttendances  EventAttendance[]
  matchPlayers      MatchPlayer[]
  scoredGoals       Goal[]        @relation("GoalScorer")
  assistedGoals     Goal[]        @relation("GoalAssist")
}

model SchedulePoll {
  id               String    @id @default(cuid())
  teamId           String
  title            String
  description      String?
  // practice | friendly | tournament | league | other
  eventType        String?
  responseDeadline DateTime?
  // open | closed | confirmed | cancelled
  status           String    @default("open")
  createdBy        String
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  team    Team                 @relation(fields: [teamId], references: [id])
  creator User                 @relation(fields: [createdBy], references: [id])
  options SchedulePollOption[]
  events  Event[]
}

model SchedulePollOption {
  id             String    @id @default(cuid())
  schedulePollId String
  startDatetime  DateTime
  endDatetime    DateTime?
  venueName      String?
  note           String?
  displayOrder   Int       @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  poll      SchedulePoll           @relation(fields: [schedulePollId], references: [id], onDelete: Cascade)
  responses SchedulePollResponse[]
}

model SchedulePollResponse {
  id                   String   @id @default(cuid())
  schedulePollOptionId String
  teamMemberId         String
  // available | maybe | unavailable
  responseType         String
  comment              String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  option     SchedulePollOption @relation(fields: [schedulePollOptionId], references: [id], onDelete: Cascade)
  teamMember TeamMember         @relation(fields: [teamMemberId], references: [id])

  @@unique([schedulePollOptionId, teamMemberId])
}

model Event {
  id            String    @id @default(cuid())
  teamId        String
  sourcePollId  String?
  title         String
  description   String?
  eventType     String?
  startDatetime DateTime
  endDatetime   DateTime?
  venueName     String?
  note          String?
  finalRank     String?
  // confirmed | cancelled
  status        String    @default("confirmed")
  createdBy     String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  team        Team              @relation(fields: [teamId], references: [id])
  sourcePoll  SchedulePoll?     @relation(fields: [sourcePollId], references: [id])
  creator     User              @relation(fields: [createdBy], references: [id])
  attendances EventAttendance[]
  matches     Match[]
}

model EventAttendance {
  id           String   @id @default(cuid())
  eventId      String
  teamMemberId String
  // attending | undecided | absent
  status       String   @default("undecided")
  comment      String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  event      Event      @relation(fields: [eventId], references: [id], onDelete: Cascade)
  teamMember TeamMember @relation(fields: [teamMemberId], references: [id])

  @@unique([eventId, teamMemberId])
}

model Match {
  id            String   @id @default(cuid())
  teamId        String
  eventId       String?
  matchOrder    Int
  opponentName  String
  ourScore      Int
  opponentScore Int
  // win | draw | loss
  result        String
  memo          String?
  matchUrl      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  team    Team          @relation(fields: [teamId], references: [id])
  event   Event?        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  players MatchPlayer[]
  goals   Goal[]
}

model MatchPlayer {
  id           String   @id @default(cuid())
  matchId      String
  teamMemberId String
  createdAt    DateTime @default(now())

  match      Match      @relation(fields: [matchId], references: [id], onDelete: Cascade)
  teamMember TeamMember @relation(fields: [teamMemberId], references: [id])

  @@unique([matchId, teamMemberId])
}

model Goal {
  id         String   @id @default(cuid())
  matchId    String
  // normal | own_goal | unknown_scorer
  goalType   String   @default("normal")
  scorerId   String?
  // none | unknown | member
  assistType String   @default("none")
  assistId   String?
  goalOrder  Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  match  Match       @relation(fields: [matchId], references: [id], onDelete: Cascade)
  scorer TeamMember? @relation("GoalScorer", fields: [scorerId], references: [id])
  assist TeamMember? @relation("GoalAssist", fields: [assistId], references: [id])
}
